{
  "include": ["src/**/*", "src/**/*.ts", "src/**/*.d.ts", "src/**/*.tsx", "src/**/*.vue", "packages/core/**/*.ts", "packages/core/**/*.d.ts", "packages/core/**/*.vue", "modules/**/*.ts", "modules/**/*.d.ts", "modules/**/*.tsx", "modules/**/*.vue"],
  "exclude": ["node_modules", "dist", "**/*.js"],
  "compilerOptions": {
    "types":["vite/client"],
    "target": "ES2022",
    "experimentalDecorators": true,
    "noImplicitAny":true,
    "importHelpers": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0",
    "downlevelIteration":true,
    "outDir": "dist/compiled",
    "allowSyntheticDefaultImports": true,
    "allowJs": true,
    "jsx": "preserve",
    "moduleResolution": "bundler",
    "module": "ES2022",
    "lib": ["ES2022", "dom"],
    "declaration": true,
    "paths": {
      "@ruoyi/core": ["./packages/core"],
      "@ruoyi/core/*": ["./packages/core/*"],
      "@": ["./src"],
      "@/*": ["./src/*"],
      "@lib": ["./lib"],
      "@lib/*": ["./lib/*"],
      "@modules": ["./modules"],
      "@modules/*": ["./modules/*"],
      "vue": ["./node_modules/vue"],
      "tslib" : ["./node_modules/tslib/tslib.d.ts"]
    }
  }
}
