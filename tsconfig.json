{
  "include": ["src/**/*", "src/**/*.ts", "src/**/*.d.ts", "src/**/*.tsx", "src/**/*.vue", "packages/**/*"],
  "exclude": ["node_modules", "dist", "**/*.js"],
  "compilerOptions": {
    "types":["vite/client"],
    "target": "ES2022",
    "ignoreDeprecations": "6.0",
    "experimentalDecorators": true,
    "noImplicitAny":true,
    "importHelpers": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "downlevelIteration":true,
    "outDir": "dist/compiled",
    "allowSyntheticDefaultImports": true,
    "allowJs": true,
    "jsx": "preserve",
    "moduleResolution": "bundler",
    "module": "ES2022",
    "lib": ["ES2022", "dom"],
    "declaration": true,
    "paths": {
      "@": ["./src"],
      "@/*": ["./src/*"],
      "@/annotation": ["./packages/core/src/annotation"],
      "@/annotation/*": ["./packages/core/src/annotation/*"],
      "@/directive": ["./packages/core/src/directive"],
      "@/directive/*": ["./packages/core/src/directive/*"],
      "@/hook": ["./packages/core/src/hook"],
      "@/hook/*": ["./packages/core/src/hook/*"],
      "@/store": ["./packages/core/src/store"],
      "@/store/*": ["./packages/core/src/store/*"],
      "@/utils": ["./packages/core/src/utils/index.js"],
      "@/utils/*": ["./packages/core/src/utils/*"],
      "@lib": ["./lib"],
      "@lib/*": ["./lib/*"],
      "@modules": ["./src/modules"],
      "@ruoyi/core": ["./packages/core/src"],
      "@ruoyi/core/*": ["./packages/core/src/*"],
      "@ruoyi/module-flowable": ["./packages/modules/module-flowable/src/index.ts"],
      "@ruoyi/module-form": ["./packages/modules/module-form/src/index.ts"],
      "@ruoyi/module-message": ["./packages/modules/module-message/src/index.ts"],
      "@ruoyi/module-online": ["./packages/modules/module-online/src/index.ts"],
      "@ruoyi/module-pay": ["./packages/modules/module-pay/src/index.ts"],
      "@flowable": ["./packages/modules/module-flowable/src"],
      "@flowable/*": ["./packages/modules/module-flowable/src/*"],
      "@form": ["./packages/modules/module-form/src"],
      "@form/*": ["./packages/modules/module-form/src/*"],
      "@message": ["./packages/modules/module-message/src"],
      "@message/*": ["./packages/modules/module-message/src/*"],
      "@online": ["./packages/modules/module-online/src"],
      "@online/*": ["./packages/modules/module-online/src/*"],
      "@pay": ["./packages/modules/module-pay/src"],
      "@pay/*": ["./packages/modules/module-pay/src/*"],
      "vue": ["./node_modules/vue"],
      "tslib" : ["./node_modules/tslib/tslib.d.ts"]
    }
  }
}
