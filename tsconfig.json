{
  "include": [
    "src/**/*",
    "src/**/*.ts",
    "src/**/*.d.ts",
    "src/**/*.tsx",
    "src/**/*.vue",
    "packages/core/**/*.ts",
    "packages/core/**/*.d.ts",
    "packages/core/**/*.vue",
    "modules/**/*.ts",
    "modules/**/*.d.ts",
    "modules/**/*.tsx",
    "modules/**/*.vue",
    "modules/pay/entity",
    "packages/core/annotation",
    "packages/core/hook",
    "packages/core/types"
  ],
  "exclude": ["node_modules", "dist", "**/*.js"],
  "compilerOptions": {
    "types": ["vite/client"],
    "target": "ES2022",
    "experimentalDecorators": true,
    "noImplicitAny": true,
    "importHelpers": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0",
    "downlevelIteration": true,
    "outDir": "dist/compiled",
    "allowSyntheticDefaultImports": true,
    "allowJs": true,
    "jsx": "preserve",
    "moduleResolution": "bundler",
    "module": "ES2022",
    "lib": ["ES2022", "dom"],
    "declaration": true,
    "paths": {
      "@ruoyi/core": ["./packages/core/src"],
      "@ruoyi/core/*": ["./packages/core/src/*"],
      "@ruoyi/module-flowable": ["./modules/flowable/src"],
      "@ruoyi/module-flowable/*": ["./modules/flowable/src/*"],
      "@ruoyi/module-form": ["./modules/form/src"],
      "@ruoyi/module-form/*": ["./modules/form/src/*"],
      "@ruoyi/module-message": ["./modules/message/src"],
      "@ruoyi/module-message/*": ["./modules/message/src/*"],
      "@ruoyi/module-online": ["./modules/online/src"],
      "@ruoyi/module-online/*": ["./modules/online/src/*"],
      "@ruoyi/module-pay": ["./modules/pay/src"],
      "@ruoyi/module-pay/*": ["./modules/pay/src/*"],
      "@": ["./src"],
      "@/*": ["./src/*"],
      "@lib": ["./lib"],
      "@lib/*": ["./lib/*"],
      "vue": ["./node_modules/vue"],
      "tslib": ["./node_modules/tslib/tslib.d.ts"]
    }
  }
}
