{
  // 使用 IntelliSense 了解相关属性。
  // 悬停以查看现有属性的描述。
  // 欲了解更多信息，请访问: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "DEV",
      "request": "launch",
      "runtimeArgs": ["run", "dev"],
      "runtimeExecutable": "npm",
      "skipFiles": ["<node_internals>/**"],
      "type": "node"
    },
    {
      "name": "Debug Edge",
      "request": "launch",
      "type": "msedge",
      "url": "http://localhost:80",
      "webRoot": "${workspaceFolder}"
    },
    {
      "name": "Debug Edge For Attach",
      "request": "attach",
      "type": "msedge",
      "port": 9222,
      "url": "http://localhost:80",
      "webRoot": "${workspaceFolder}"
      // msedge --remote-debugging-port=9222
      // msedge --remote-debugging-port=9222
    }
  ],
  "compounds": [
    {
      "name": "Debug All",
      "configurations": ["DEV", "Debug Edge"],
      "presentation": {
        "order": 1
      }
    }
  ]
}
